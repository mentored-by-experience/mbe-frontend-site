# YouTube embed URL for the home page's "latest episode" video.
# Format: https://www.youtube.com/embed/<VIDEO_ID>
LATEST_VIDEO_EMBED_URL=

# Google Apps Script Web App URLs (one per application form).
# See the setup steps for creating these.
MENTEE_APPS_SCRIPT_URL=
MENTOR_APPS_SCRIPT_URL=

# Shared secret checked by both Apps Script web apps before appending a row.
# Pick any random string and use the same value in both scripts.
SHEETS_WEBHOOK_SECRET=

# Social media links shown in the footer. Leave blank until you have the
# real profile URLs -- unset links fall back to "#" placeholders.
INSTAGRAM_URL=
X_URL=
TIKTOK_URL=
YOUTUBE_URL=

# Set to "false" to hide the social links row entirely without a code change.
FEATURE_SOCIAL_LINKS=
